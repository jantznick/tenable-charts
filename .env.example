# Tenable.io API keys (Settings → API Keys)
TENABLE_ACCESS_KEY=
TENABLE_SECRET_KEY=

# Optional: default https://cloud.tenable.com
# TENABLE_BASE_URL=https://cloud.tenable.com

# --- Web App Scanning (WAS) search defaults ---
# POST /was/v2/vulnerabilities/search — https://developer.tenable.com/reference/was-v2-vulns-search
# List valid field names/operators: GET /was/v2/vulnerabilities/filters
#
# Tag filter: your company’s tag UUID (must match a filter field in your tenant)
# TENABLE_WAS_TAG_FIELD=tag
# TENABLE_WAS_TAG_OPERATOR=eq
#
# Time window (default 30 days); CLI --since-days overrides
# TENABLE_WAS_SINCE_DAYS=30
# TENABLE_WAS_DATE_FIELD=created_at
# TENABLE_WAS_DATE_OPERATOR=gte
#
# Exclude informational severity (adjust field/value if your filters differ)
# TENABLE_WAS_SEVERITY_FIELD=severity
# TENABLE_WAS_SEVERITY_OPERATOR=neq
# TENABLE_WAS_SEVERITY_INFO_VALUE=info
#
# Extra AND filters (JSON array of { field, operator, value })
# TENABLE_WAS_EXTRA_FILTERS_JSON=[]
#
# Full override of POST body (single filter OR { "AND": [...] })
# TENABLE_WAS_SEARCH_BODY_JSON=
